generator client {
  provider = "prisma-client-js"
  output   = "../client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcessingStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

model CadModel {
  id                  String           @id @default(uuid())
  name                String
  originalFilename    String
  storageKey          String
  processedStorageKey String?
  status              ProcessingStatus @default(UPLOADED)
  fileSize            Int
  mimeType            String
  metadata            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
