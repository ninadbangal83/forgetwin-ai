generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcessingStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

model CadModel {
  id                  String           @id @default(uuid())
  name                String
  originalFilename    String
  storageKey          String
  processedStorageKey String?
  status              ProcessingStatus @default(UPLOADED)
  fileSize            Int
  mimeType            String
  metadata            Json?
  assemblyTree        Json?
  bomVariations       Json?
  topologyInfo        Json?
  aiEnrichment        Json?
  engineeringTags     Json?
  thumbnailKey        String?
  
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingDurationMs  Int?
  processingLogs        String[]
  correlationId         String?

  userId              String?
  user                User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  versions            CadModelVersion[]
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String?
  role      String     @default("USER")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cadModels CadModel[]

  @@index([email])
}

model CadModelVersion {
  versionId       String       @id @default(uuid())
  modelId         String
  versionNumber   Int
  parentVersionId String?
  createdAt       DateTime     @default(now())
  createdBy       String?
  reviewStatus    String       @default("DRAFT")
  snapshotData    Json
  
  cadModel        CadModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  annotations     Annotation[]
  shareLinks      ShareLink[]

  @@index([modelId])
  @@index([createdAt])
}

model Annotation {
  annotationId  String          @id @default(uuid())
  versionId     String
  partId        String?
  worldPosition Json?
  note          String
  createdBy     String?
  createdAt     DateTime        @default(now())

  cadVersion    CadModelVersion @relation(fields: [versionId], references: [versionId], onDelete: Cascade)

  @@index([versionId])
}

model ShareLink {
  token         String          @id @default(uuid())
  versionId     String
  expiresAt     DateTime?
  permissions   String          @default("READ_ONLY")

  cadVersion    CadModelVersion @relation(fields: [versionId], references: [versionId], onDelete: Cascade)

  @@index([versionId])
}


